    for var in policy_vars:
        df[var + '_std'] = (df[var] - df[var].mean()) / df[var].std()
    df = df.set_index(['country', 'year'])
    df['ln_gdp_per_capita_lag1'] = df.groupby('country')['ln_gdp_per_capita'].shift(1)
