    print("\n--- Diagnostic Statistics ---")
    print("Hansen J-test P-value: " + str(round(res.hansen.pvalue, 4)))
    print("Arellano-Bond AR(2) P-value: " + str(round(res.arellano_bond(2).pvalue, 4)))

if __name__ == "__main__":
    run_analysis()
